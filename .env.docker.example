# Docker Compose overrides (copy values into repo-root .env)
# The browser calls the API on the host loopback — keep NEXT_PUBLIC_API_URL as 127.0.0.1:8080

VERTEX_SEARCH_SERVING_CONFIG=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=
VERTEX_DATA_STORE_ID=
VERTEX_DATA_STORE_BRANCH=

# Host path to service account JSON (mounted into api/indexer containers)
# GCP_SA_MOUNT=C:/path/to/.secrets/quickpickr-sa.json

REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

NEXT_PUBLIC_API_URL=http://127.0.0.1:8080
EXPO_PUBLIC_API_URL=http://127.0.0.1:8080
