# Vertex AI Search (required for query service)
# Full resource name of your serving config, e.g.:
# projects/PROJECT_ID/locations/global/collections/default_collection/engines/ENGINE_ID/servingConfigs/default_search
VERTEX_SEARCH_SERVING_CONFIG=

# Path to GCP service account JSON with Discovery Engine / Vertex AI Search access
GOOGLE_APPLICATION_CREDENTIALS=

# Frontend → query service
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080
EXPO_PUBLIC_API_URL=http://127.0.0.1:8080

# Optional (query service)
VERTEX_PAGE_SIZE=25
SEARCH_CACHE_TTL_SECONDS=60
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://127.0.0.1:8080
