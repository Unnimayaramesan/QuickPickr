# Vertex AI Search (Discovery Engine) — required for query service
#
# VERTEX_SEARCH_SERVING_CONFIG — full resource name of the Serving Config (not just engine id).
# Get it from: GCP Console → Vertex AI → Vertex AI Search → your engine → Serving configs
# → copy "Resource name" (often ends with .../servingConfigs/default_search).
# Docs: https://cloud.google.com/generative-ai-app-builder/docs/configure-serving-controls
#
# Example shape (replace PROJECT and ENGINE_ID):
# VERTEX_SEARCH_SERVING_CONFIG=projects/PROJECT_NUM/locations/global/collections/default_collection/engines/ENGINE_ID/servingConfigs/default_search
VERTEX_SEARCH_SERVING_CONFIG=

# GOOGLE_APPLICATION_CREDENTIALS — absolute path to a service account JSON key (local dev).
# Create SA: IAM → Service accounts → Keys → JSON. Grant at least roles/discoveryengine.user
# for search; add discoveryengine.editor (or import-capable role) if running the indexer.
# Production Cloud Run: use Workload Identity on the service account instead of this file.
GOOGLE_APPLICATION_CREDENTIALS=

# GCP project id (Terraform / scripts / indexer ops — optional for query-only dev)
GOOGLE_CLOUD_PROJECT=

# Discovery Engine data store id short name (console label); branch resource uses VERTEX_DATA_STORE_BRANCH for imports
VERTEX_DATA_STORE_ID=

# Frontend → query service
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080
EXPO_PUBLIC_API_URL=http://127.0.0.1:8080

# Optional (query service)
VERTEX_PAGE_SIZE=25
# false until retailer + zoneId facets exist in Vertex (faster: one search call per retailer)
VERTEX_USE_SCHEMA_FILTERS=false
SEARCH_CACHE_TTL_SECONDS=60
REDIS_URL=
RETAILER_SEARCH_TIMEOUT_MS=3500
TOTAL_SEARCH_BUDGET_SEC=5.0
ENABLE_RATE_LIMIT=true
MATCH_ENGINE_SUPPRESS_THRESHOLD=0.34
MATCH_ENGINE_LOW_THRESHOLD=0.52
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://127.0.0.1:8080

# Indexer / Cloud Run Job (import documents branch parent)
VERTEX_DATA_STORE_BRANCH=
